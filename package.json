{
  "name": "zabs-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:cms": "npm --prefix apps/cms run dev",
    "build": "npm run build:web && npm run build:cms",
    "build:web": "npm --prefix apps/web run build",
    "build:cms": "npm --prefix apps/cms run build",
    "start": "npm run start:web",
    "start:web": "npm --prefix apps/web run start",
    "start:cms": "npm --prefix apps/cms run start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@headlessui/react": "^2.2.10",
    "@payloadcms/db-mongodb": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "clsx": "^2.1.1",
    "graphql": "^16.14.1",
    "graphql-http": "^1.22.4",
    "lucide-react": "^0.469.0",
    "next": "^15.4.11",
    "payload": "^3.85.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.4.11",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0"
  },
  "workspaces": [
    "apps/web",
    "apps/cms"
  ]
}
